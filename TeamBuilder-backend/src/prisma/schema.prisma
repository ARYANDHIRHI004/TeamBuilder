// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum STATUS {
  ACTIVE
  INACTIVE
}

enum Teamroles {
  TEAM_LEAD
  MEMBER
}

enum UserRole {
  ADMIN
  SUPERADMIN
  STUDENT
}


model User {
  id                String   @id @default(uuid())
  name              String
  email             String   @unique
  address           String?
  roles             UserRole[]
  isEmailVerified   Boolean  @default(false)

  sessions          Session[]
  teamMemberships   TeamMember[]
  applications      TeamJoiningApplication[]

  reviewsGiven      Review[] @relation("ReviewsGiven")
  reviewsReceived   Review[] @relation("ReviewsReceived")

  registeredCourses RegisteredUser[]

  histories         History[] @relation("UserHistory")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Course {
  id                String   @id @default(uuid())
  courseName        String
  courseDescription String?

  teams             Team[]
  registeredUsers   RegisteredUser[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Team {
  id                String   @id @default(uuid())
  teamName          String   @unique
  teamDescription   String?

  courseId          String
  course            Course   @relation(fields: [courseId], references: [id])

  status            STATUS   @default(ACTIVE)
  hiring            STATUS @default(ACTIVE)

  members           TeamMember[]
  applications      TeamJoiningApplication[]
  notes             Note[]

  reviewsReceived   Review[] @relation("TeamReviews")

  histories         History[] @relation("TeamHistory")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TeamMember {
  id          String         @id @default(uuid())

  memberId    String
  member      User           @relation(fields: [memberId], references: [id], onDelete: Cascade)

  teamId      String
  team        Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  role        Teamroles @default(MEMBER)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([memberId, teamId])
}

model TeamJoiningApplication {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])

  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Note {
  id          String   @id @default(uuid())

  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])

  note        String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id          String   @id @default(uuid())

  review      String

  givenById   String
  givenBy     User     @relation("ReviewsGiven", fields: [givenById], references: [id])

  // Review can be given to either a User or a Team
  givenToUserId String?
  givenToUser   User?   @relation("ReviewsReceived", fields: [givenToUserId], references: [id])

  givenToTeamId String?
  givenToTeam   Team?   @relation("TeamReviews", fields: [givenToTeamId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RegisteredUser {
  id          String   @id @default(uuid())

  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])

  userEmail   String

  user        User?    @relation(fields: [userEmail], references: [email])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Session {
  id            String   @id @default(uuid())

  refreshToken  String
  sessions      Int

  userId        String
  user          User     @relation(fields: [userId], references: [id])

  systemIP      String?
  device        String?
  browser       String?

  latitude      Float?
  longitude     Float?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Subscription {
  id          String   @id @default(uuid())
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model History {
  id          String   @id @default(uuid())

  description String

  // Either User or Team history
  userId      String?
  user        User?    @relation("UserHistory", fields: [userId], references: [id])

  teamId      String?
  team        Team?    @relation("TeamHistory", fields: [teamId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}